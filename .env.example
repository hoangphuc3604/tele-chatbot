# Telegram Bot
BOT_TOKEN=your_bot_token_here

# Google AI (Get from https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=your_google_api_key_here

# Database (PostgreSQL)
# Railway: postgresql+psycopg2://user:pass@host:port/dbname
# Neon: postgresql+psycopg2://user:pass@host/dbname
# Local: postgresql+psycopg2://postgres:password@localhost:5432/inkliu_bot
DATABASE_URL=postgresql+psycopg2://user:pass@host:port/dbname

# Optional: Redis (for caching/scaling)
# REDIS_URL=redis://localhost:6379/0

# Optional: Debug mode
# DEBUG=true
